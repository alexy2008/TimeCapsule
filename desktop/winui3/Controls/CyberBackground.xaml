<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HelloTimeWinUI.Controls.CyberBackground"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid IsHitTestVisible="False">
        <Rectangle Fill="{StaticResource CyberWindowBackgroundBrush}" />

        <Canvas Opacity="0.28">
            <Line X1="40" Y1="0" X2="40" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="120" Y1="0" X2="120" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="200" Y1="0" X2="200" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="280" Y1="0" X2="280" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="360" Y1="0" X2="360" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="440" Y1="0" X2="440" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="520" Y1="0" X2="520" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="600" Y1="0" X2="600" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="680" Y1="0" X2="680" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="760" Y1="0" X2="760" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="840" Y1="0" X2="840" Y2="1200" Stroke="#2A7DD3FC" StrokeThickness="1" />
            <Line X1="920" Y1="0" X2="920" Y2="1200" Stroke="#221B6CA8" StrokeThickness="1" />
            <Line X1="0" Y1="40" X2="1800" Y2="40" Stroke="#1F7DD3FC" StrokeThickness="1" />
            <Line X1="0" Y1="120" X2="1800" Y2="120" Stroke="#191B6CA8" StrokeThickness="1" />
            <Line X1="0" Y1="200" X2="1800" Y2="200" Stroke="#1F7DD3FC" StrokeThickness="1" />
            <Line X1="0" Y1="280" X2="1800" Y2="280" Stroke="#191B6CA8" StrokeThickness="1" />
            <Line X1="0" Y1="360" X2="1800" Y2="360" Stroke="#1F7DD3FC" StrokeThickness="1" />
            <Line X1="0" Y1="440" X2="1800" Y2="440" Stroke="#191B6CA8" StrokeThickness="1" />
            <Line X1="0" Y1="520" X2="1800" Y2="520" Stroke="#1F7DD3FC" StrokeThickness="1" />
            <Line X1="0" Y1="600" X2="1800" Y2="600" Stroke="#191B6CA8" StrokeThickness="1" />
            <Line X1="0" Y1="680" X2="1800" Y2="680" Stroke="#1F7DD3FC" StrokeThickness="1" />
            <Line X1="0" Y1="760" X2="1800" Y2="760" Stroke="#191B6CA8" StrokeThickness="1" />
        </Canvas>

        <Ellipse
            Width="720"
            Height="720"
            Margin="-140,-120,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#4444E3FF" Offset="0" />
                    <GradientStop Color="#1144E3FF" Offset="0.45" />
                    <GradientStop Color="#0044E3FF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse
            Width="560"
            Height="560"
            Margin="0,60,-180,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#3334D399" Offset="0" />
                    <GradientStop Color="#1034D399" Offset="0.55" />
                    <GradientStop Color="#0034D399" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
    </Grid>
</UserControl>
