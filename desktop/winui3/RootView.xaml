<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HelloTimeWinUI.RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HelloTimeWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <controls:CyberBackground />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="24,20,24,16"
                Padding="20"
                Style="{StaticResource CyberPanelStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource CyberTextBrush}"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="HelloTime Cyber" />
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            Text="WinUI 3 原生桌面实现，目标贴近 macOS SwiftUI 的赛博玻璃体验。" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button x:Name="HomeNavButton" Click="OnNavigateHome" Content="首页" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button x:Name="CreateNavButton" Click="OnNavigateCreate" Content="创建" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button x:Name="OpenNavButton" Click="OnNavigateOpen" Content="开启" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button x:Name="AboutNavButton" Click="OnNavigateAbout" Content="关于" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button x:Name="AdminNavButton" Click="OnNavigateAdmin" Content="管理" Style="{StaticResource CyberNavButtonStyle}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Spacing="10">
                        <Button
                            Click="OnToggleTheme"
                            Content="切换主题"
                            Style="{StaticResource CyberNavButtonStyle}" />
                        <TextBlock
                            MaxWidth="220"
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            Text="{Binding StatusMessage}"
                            TextAlignment="Right"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </Border>

            <Frame
                x:Name="ContentFrame"
                Grid.Row="1"
                Margin="24,0,24,20" />

            <Border
                Grid.Row="2"
                Margin="24,0,24,24"
                Padding="16,12"
                Style="{StaticResource CyberPanelStyle}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Rectangle
                        Height="1"
                        HorizontalAlignment="Stretch"
                        Fill="{StaticResource CyberGlassLineBrush}" />

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TechStackItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,10,10"
                                    Padding="12,8"
                                    Background="#1A56CCF2"
                                    BorderBrush="{StaticResource CyberPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            Foreground="{StaticResource CyberMutedTextBrush}"
                                            FontSize="12"
                                            Text="{Binding Category}" />
                                        <TextBlock
                                            Foreground="{StaticResource CyberTextBrush}"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
