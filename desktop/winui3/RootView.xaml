<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HelloTimeWinUI.RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HelloTimeWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <controls:CyberBackground />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: Tauri-style simple bar with logo + nav + theme toggle -->
            <Border
                Grid.Row="0"
                Padding="60,24">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <Button
                        Grid.Column="0"
                        Click="OnNavigateHome"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        HorizontalContentAlignment="Left"
                        Padding="0"
                        ToolTipService.ToolTip="返回首页">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image
                                Source="ms-appx:///Assets/logo.svg"
                                Width="28"
                                Height="28" />
                            <TextBlock
                                Foreground="{StaticResource CyberTextBrush}"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="HelloTime"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Spacer -->
                    <Grid Grid.Column="1" />

                    <!-- Right side: About link + Theme Toggle -->
                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="20"
                        VerticalAlignment="Center">
                        <Button Click="OnNavigateAbout" Content="关于项目" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button
                            Click="OnToggleTheme"
                            FontSize="18"
                            Padding="10"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            ToolTipService.ToolTip="切换主题">
                            <FontIcon Glyph="&#xE703;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Frame -->
            <Frame
                x:Name="ContentFrame"
                Grid.Row="1"
                Margin="60,0,60,40" />

            <!-- Footer: status dot + tech stack summary -->
            <Border
                Grid.Row="2"
                Margin="60,0,60,32"
                Padding="20,12"
                Background="{StaticResource CyberPanelBrush}"
                BorderBrush="{StaticResource CyberPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Ellipse
                        Width="8"
                        Height="8"
                        Fill="{StaticResource CyberGreenNeonBrush}" />
                    <TextBlock
                        Foreground="{StaticResource CyberMutedTextBrush}"
                        FontSize="12"
                        Text="{Binding StatusMessage}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
