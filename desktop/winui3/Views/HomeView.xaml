<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HelloTimeWinUI.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Disabled">
        <StackPanel HorizontalAlignment="Center" Spacing="28" MaxWidth="900">

            <!-- Hero Section -->
            <StackPanel Spacing="20" HorizontalAlignment="Center" Margin="0,40,0,40">
                <!-- Badge: TIMECAPSULE SYSTEM -->
                <Border
                    Padding="12,4"
                    Background="#0D00F0FF"
                    BorderBrush="#3300F0FF"
                    BorderThickness="1"
                    CornerRadius="100"
                    HorizontalAlignment="Center">
                    <TextBlock
                        Foreground="{StaticResource CyberAccentBrush}"
                        CharacterSpacing="120"
                        FontFamily="Consolas"
                        FontSize="11"
                        FontWeight="Bold"
                        Text="TIMECAPSULE PROTOCOL v1.0" />
                </Border>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock
                        Foreground="{StaticResource CyberTextBrush}"
                        FontSize="56"
                        FontWeight="Bold"
                        Text="封存此刻 " />
                    <TextBlock
                        Foreground="{StaticResource CyberAccentBrush}"
                        FontSize="56"
                        FontWeight="Bold"
                        Text="开启未来" />
                </StackPanel>

                <!-- Subtitle -->
                <TextBlock
                    MaxWidth="640"
                    Foreground="{StaticResource CyberMutedTextBrush}"
                    FontSize="18"
                    LineHeight="28"
                    Text="将您的寄语、秘密或愿景封装于数字时间胶囊中，直到指定的未来时刻才能被再次唤醒。"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <!-- Action Cards -->
            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Create Capsule Card (Cyan) -->
                <Button
                    Grid.Column="0"
                    Click="OnGoCreateClicked"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Padding="40,32"
                    Background="{StaticResource CyberPanelBrush}"
                    BorderBrush="{StaticResource CyberPanelBorderBrush}"
                    BorderThickness="1,2,1,1"
                    CornerRadius="12">
                    <StackPanel Spacing="20" HorizontalAlignment="Left">
                        <Border
                            Width="64"
                            Height="64"
                            Background="#1A00F0FF"
                            CornerRadius="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="{StaticResource CyberAccentBrush}"
                                Glyph="&#xE710;" />
                        </Border>
                        <TextBlock
                            Foreground="{StaticResource CyberTextBrush}"
                            FontSize="26"
                            FontWeight="Bold"
                            Text="创建胶囊" />
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            FontSize="15"
                            Text="封存此刻寄语，投递给未来的自己"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Button>

                <!-- Open Capsule Card (Magenta) -->
                <Button
                    Grid.Column="1"
                    Click="OnGoOpenClicked"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Padding="40,32"
                    Background="{StaticResource CyberPanelBrush}"
                    BorderBrush="{StaticResource CyberPanelBorderBrush}"
                    BorderThickness="1,2,1,1"
                    CornerRadius="12">
                    <StackPanel Spacing="20" HorizontalAlignment="Left">
                        <Border
                            Width="64"
                            Height="64"
                            Background="#1AFF003C"
                            CornerRadius="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="{StaticResource CyberMagentaBrush}"
                                Glyph="&#xE721;" />
                        </Border>
                        <TextBlock
                            Foreground="{StaticResource CyberTextBrush}"
                            FontSize="26"
                            FontWeight="Bold"
                            Text="开启胶囊" />
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            FontSize="15"
                            Text="输入提取凭据，唤醒沉睡的时间印记"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Tech Stack Section -->
            <Border 
                Margin="0,40,0,0"
                Padding="32,24" 
                Background="Transparent"
                BorderBrush="{StaticResource CyberPanelBorderBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel Spacing="20">
                    <TextBlock
                        Foreground="{StaticResource CyberMutedTextBrush}"
                        CharacterSpacing="200"
                        FontFamily="Consolas"
                        FontSize="11"
                        Opacity="0.6"
                        Text="TECHNOLOGY STACK" />

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 1. WinUI 3 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                            <Image x:Name="TechLogo0" Width="24" Height="24" />
                            <TextBlock
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Text="WinUI 3" />
                        </StackPanel>

                        <!-- 2. C# -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Image x:Name="TechLogo1" Width="24" Height="24" />
                            <TextBlock
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Text="C#" />
                        </StackPanel>

                        <!-- 3. Backend Framework -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                            <Image x:Name="TechLogo2" Width="24" Height="24" />
                            <TextBlock
                                x:Name="TechLabel2"
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Text="..." />
                        </StackPanel>

                        <!-- 4. Backend Language -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
                            <Image x:Name="TechLogo3" Width="24" Height="24" />
                            <TextBlock
                                x:Name="TechLabel3"
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Text="..." />
                        </StackPanel>

                        <!-- 5. Database -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10">
                            <Image x:Name="TechLogo4" Width="24" Height="24" />
                            <TextBlock
                                x:Name="TechLabel4"
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Text="..." />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
