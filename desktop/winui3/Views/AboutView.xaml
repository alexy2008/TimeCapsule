<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HelloTimeWinUI.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Ellipse
                Width="360"
                Height="360"
                Margin="0,-40,-120,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Opacity="0.55">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3334D399" Offset="0" />
                        <GradientStop Color="#0034D399" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel Spacing="24">
                <Border Padding="32" Style="{StaticResource CyberPanelStyle}">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Click="OnOrbClicked"
                            Width="240"
                            Height="240"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            BorderBrush="{x:Null}">
                            <Grid>
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="OrbRotateTransform" />
                                </Grid.RenderTransform>
                                <Ellipse Fill="#2034D399" />
                                <Ellipse
                                    Width="180"
                                    Height="180"
                                    Stroke="{StaticResource CyberAccentStrongBrush}"
                                    StrokeThickness="2" />
                                <Ellipse
                                    Width="210"
                                    Height="210"
                                    Stroke="#6689F7FF"
                                    StrokeThickness="1.5"
                                    StrokeDashArray="4 6" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource CyberTextBrush}"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="HELLOTIME" />
                            </Grid>
                        </Button>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <TextBlock
                                Foreground="{StaticResource CyberTextBrush}"
                                FontSize="32"
                                FontWeight="SemiBold"
                                Text="关于 HelloTime Cyber" />
                            <TextBlock
                                MaxWidth="720"
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                Text="HelloTime 不仅是一个时间胶囊应用，也是一个遵循统一 API 契约的实验性多实现项目。Windows 版延续顶部导航、单页切换与桌面端技术栈展示规则，同时把 WinUI 3 的窗口层次、Mica 背景和 C# 异步交互融入赛博玻璃体验。"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="HiddenHintText"
                                Foreground="{StaticResource CyberAccentBrush}"
                                Text="连续点击科技球 5 次，可快速进入管理员界面。" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="22" Style="{StaticResource CyberPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="24" Text="🛸" />
                            <TextBlock
                                Foreground="{StaticResource CyberTextBrush}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="统一 API 交互" />
                            <TextBlock
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                Text="无论底层后端使用 Java、Go 还是 Python，客户端只对接同一套 REST 契约。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="22" Style="{StaticResource CyberPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="24" Text="🌗" />
                            <TextBlock
                                Foreground="{StaticResource CyberTextBrush}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="设计系统同步" />
                            <TextBlock
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                Text="赛博玻璃、光晕、网格背景与锁定表达保持跨端一致，但会为 WinUI 3 保留原生窗口手感。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="22" Style="{StaticResource CyberPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="24" Text="⛓️" />
                            <TextBlock
                                Foreground="{StaticResource CyberTextBrush}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="时间锁定安全" />
                            <TextBlock
                                Foreground="{StaticResource CyberMutedTextBrush}"
                                Text="未到开启时间时，服务端不会返回内容；客户端只展示锁定态、倒计时与状态提示。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="28" Style="{StaticResource CyberPanelStyle}">
                    <StackPanel Spacing="24">
                        <TextBlock
                            Foreground="{StaticResource CyberAccentBrush}"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="核心驱动 (Core Technologies)" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Padding="18" Background="#140D1E2F" CornerRadius="18">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock FontSize="28" Text="🪟" />
                                    <TextBlock Foreground="{StaticResource CyberTextBrush}" FontWeight="SemiBold" Text="WinUI 3" />
                                    <TextBlock Foreground="{StaticResource CyberMutedTextBrush}" FontSize="12" Text="Desktop Core" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="18" Background="#140D1E2F" CornerRadius="18">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock FontSize="28" Text="C#" />
                                    <TextBlock Foreground="{StaticResource CyberTextBrush}" FontWeight="SemiBold" Text="C#" />
                                    <TextBlock Foreground="{StaticResource CyberMutedTextBrush}" FontSize="12" Text="UI Layer" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Padding="18" Background="#140D1E2F" CornerRadius="18">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock FontSize="28" Text="⚙" />
                                    <TextBlock x:Name="BackendFrameworkText" Foreground="{StaticResource CyberTextBrush}" FontWeight="SemiBold" Text="Backend" />
                                    <TextBlock x:Name="BackendFrameworkSubText" Foreground="{StaticResource CyberMutedTextBrush}" FontSize="12" Text="服务框架" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Padding="18" Background="#140D1E2F" CornerRadius="18">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock FontSize="28" Text="&lt;/&gt;" />
                                    <TextBlock x:Name="BackendLanguageText" Foreground="{StaticResource CyberTextBrush}" FontWeight="SemiBold" Text="Language" />
                                    <TextBlock x:Name="BackendLanguageSubText" Foreground="{StaticResource CyberMutedTextBrush}" FontSize="12" Text="服务语言" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Padding="18" Background="#140D1E2F" CornerRadius="18">
                                <StackPanel HorizontalAlignment="Center" Spacing="10">
                                    <TextBlock FontSize="28" Text="🗄" />
                                    <TextBlock x:Name="DatabaseText" Foreground="{StaticResource CyberTextBrush}" FontWeight="SemiBold" Text="SQLite" />
                                    <TextBlock x:Name="DatabaseSubText" Foreground="{StaticResource CyberMutedTextBrush}" FontSize="12" Text="存储层" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
