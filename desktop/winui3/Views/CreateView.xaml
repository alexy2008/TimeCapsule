<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HelloTimeWinUI.Views.CreateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Border x:Name="FormPanel" Padding="32" Style="{StaticResource CyberPanelStyle}">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Foreground="{StaticResource CyberTextBrush}"
                            FontSize="32"
                            FontWeight="SemiBold"
                            Text="创建时间胶囊" />
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            Text="把此刻的内容封存起来，等未来的某个时间再开启。一旦创建成功，内容与开启时间都不可修改。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <TextBlock
                        x:Name="ErrorText"
                        Foreground="#FF8FB8"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />

                    <TextBox
                        x:Name="TitleInput"
                        Header="标题"
                        PlaceholderText="写下一句想留给未来的话" />
                    <TextBox
                        x:Name="CreatorInput"
                        Header="创建者"
                        PlaceholderText="你的昵称（默认匿名访客）" />
                    <DatePicker x:Name="OpenDateInput" Header="开启日期" />
                    <TextBox
                        x:Name="ContentInput"
                        Header="内容"
                        AcceptsReturn="True"
                        Height="180"
                        TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="CreateButton"
                            Click="OnCreateClicked"
                            Content="封存胶囊"
                            Style="{StaticResource CyberNavButtonStyle}" />
                        <ProgressRing
                            x:Name="CreateProgress"
                            Width="28"
                            Height="28"
                            IsActive="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                x:Name="SuccessPanel"
                Padding="32"
                Style="{StaticResource CyberPanelStyle}"
                Visibility="Collapsed">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Foreground="{StaticResource CyberSuccessBrush}"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="胶囊创建成功" />
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            Text="你的时间胶囊已经成功封存。请保存好胶囊码，它是唯一的开启凭证。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        Padding="20"
                        Background="#140D1E2F"
                        BorderBrush="{StaticResource CyberPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="{StaticResource CyberMutedTextBrush}" Text="胶囊码" />
                            <TextBlock
                                x:Name="CreatedCodeText"
                                Foreground="{StaticResource CyberAccentStrongBrush}"
                                FontFamily="Consolas"
                                FontSize="28"
                                FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Click="OnCopyCodeClicked" Content="复制提取码" Style="{StaticResource CyberNavButtonStyle}" />
                                <TextBlock
                                    x:Name="CopyHintText"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource CyberSuccessBrush}"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="#16233B55"
                        BorderBrush="{StaticResource CyberPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <TextBlock
                            Foreground="{StaticResource CyberMutedTextBrush}"
                            Text="请务必妥善保存胶囊码。它是开启此胶囊的唯一凭证，丢失后将无法找回或补发。"
                            TextWrapping="WrapWholeWords" />
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="OnCreateAnotherClicked" Content="继续创建" Style="{StaticResource CyberNavButtonStyle}" />
                        <Button Click="OnGoOpenClicked" Content="去开启页面" Style="{StaticResource CyberNavButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
