#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
cd "$SCRIPT_DIR"

export PATH="/opt/homebrew/opt/ruby/bin:/opt/homebrew/lib/ruby/gems/4.0.0/bin:$PATH"

bundle check > /dev/null 2>&1 || bundle install

bundle exec rails db:migrate RAILS_ENV=development 2>/dev/null || true

exec bundle exec rails server -p "${PORT:-5181}" -b localhost
